{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Workflow Runs (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(agentloom_workflow_runs_total[5m])",
          "legendFormat": "{{workflow}} - {{status}}"
        }
      ]
    },
    {
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(agentloom_tokens_total) * 0.00001",
          "legendFormat": "Estimated Cost"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 }
      }
    },
    {
      "title": "Tokens Consumed (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(agentloom_tokens_total[5m])",
          "legendFormat": "{{provider}}/{{model}} ({{direction}})"
        }
      ]
    },
    {
      "title": "Step Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agentloom_step_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{step_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Provider Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agentloom_provider_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Provider Errors (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(agentloom_provider_errors_total[5m])",
          "legendFormat": "{{provider}} - {{error_type}}"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "agentloom_circuit_breaker_state",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF-OPEN", "color": "yellow" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentloom"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AgentLoom Dashboard",
  "uid": "agentloom-main"
}
